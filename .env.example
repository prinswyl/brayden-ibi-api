# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Brayden IBI API"
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=console

# ─── Database ─────────────────────────────────────────────────────────────────
# Async PostgreSQL DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/brayden_ibi
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Found in Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_AUDIENCE=authenticated

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list or JSON array
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=true

# ─── Storage ──────────────────────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET_COMPLIANCE=compliance-docs
SUPABASE_STORAGE_BUCKET_PAYROLL=payroll-exports
SUPABASE_STORAGE_BUCKET_ASSETS=trust-assets
SUPABASE_STORAGE_SIGNED_URL_TTL=900

# ─── Security ─────────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
REQUEST_ID_HEADER=X-Request-ID
