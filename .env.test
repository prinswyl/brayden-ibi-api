ENVIRONMENT=test
DEBUG=true
LOG_LEVEL=WARNING
LOG_FORMAT=console

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/brayden_ibi_test
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=2
DATABASE_POOL_TIMEOUT=10

SUPABASE_URL=https://test.supabase.co
SUPABASE_ANON_KEY=test-anon-key
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key
SUPABASE_JWT_SECRET=test-super-secret-jwt-key-that-is-long-enough
JWT_ALGORITHM=HS256
JWT_AUDIENCE=authenticated

CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

SUPABASE_STORAGE_BUCKET_COMPLIANCE=compliance-docs
SUPABASE_STORAGE_BUCKET_PAYROLL=payroll-exports
SUPABASE_STORAGE_BUCKET_ASSETS=trust-assets
SUPABASE_STORAGE_SIGNED_URL_TTL=900

RATE_LIMIT_REQUESTS_PER_MINUTE=1000
REQUEST_ID_HEADER=X-Request-ID
